# Agent Nexus - Caddy Configuration
# Copy this to /etc/caddy/Caddyfile

# Static files (existing)
:{$NEXUS_DEPLOY_PUBLIC_PORT:18888} {
    root * /home/pets/publish-pages
    encode zstd gzip
    file_server

    # Agent Nexus API proxy
    handle /nexus/* {
        uri strip_prefix /nexus
        reverse_proxy 127.0.0.1:{$NEXUS_BACKEND_PORT:18890}
    }
}
