# Optional override when you open Next.js directly on :3000 in local development.
# For published access through Caddy (:8888), leave NEXT_PUBLIC_API_URL unset
# so the browser uses the current origin for /api and /ws.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend runtime limits and intervals
NEXT_PUBLIC_BACKEND_PORT=18890
NEXT_PUBLIC_WS_RECONNECT_MS=5000
NEXT_PUBLIC_WS_PING_INTERVAL_MS=30000
NEXT_PUBLIC_DASHBOARD_SESSIONS_LIMIT=100
NEXT_PUBLIC_COMPLETED_SESSIONS_PREVIEW_LIMIT=20
