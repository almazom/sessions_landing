{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "session-query-result.schema.json",
  "title": "SessionQueryResult",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "meta",
    "source",
    "question",
    "answer"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "tool",
        "tool_version",
        "generated_at",
        "answer_source",
        "reasoning_mode"
      ],
      "properties": {
        "tool": {
          "type": "string"
        },
        "tool_version": {
          "type": "string"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "answer_source": {
          "type": "string",
          "enum": [
            "local_artifact"
          ]
        },
        "reasoning_mode": {
          "type": "string",
          "enum": [
            "lexical_evidence_match"
          ]
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": [
        "format",
        "record_count",
        "snippet_count",
        "user_message_count"
      ],
      "properties": {
        "harness_provider": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "jsonl"
          ]
        },
        "record_count": {
          "type": "integer",
          "minimum": 0
        },
        "snippet_count": {
          "type": "integer",
          "minimum": 0
        },
        "user_message_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "question": {
      "type": "object",
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "answer": {
      "type": "object",
      "required": [
        "mode",
        "response",
        "confidence",
        "evidence",
        "limitations"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "ask-only"
          ]
        },
        "response": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "kind",
              "label",
              "excerpt",
              "score"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "user_message",
                  "assistant_message",
                  "timeline",
                  "artifact_field"
                ]
              },
              "label": {
                "type": "string"
              },
              "excerpt": {
                "type": "string"
              },
              "score": {
                "type": "number",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
