{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "session-collect-request.schema.json",
  "title": "SessionCollectRequest",
  "version": "2.3.0",
  "type": "object",
  "required": [
    "catalog",
    "query"
  ],
  "properties": {
    "catalog": {
      "type": "object",
      "required": [
        "providers"
      ],
      "properties": {
        "providers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "codex",
              "claude",
              "gemini",
              "qwen",
              "pi",
              "kimi"
            ]
          }
        },
        "config_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "query": {
      "type": "object",
      "required": [
        "mode",
        "timezone",
        "live_within_minutes",
        "active_within_minutes"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "latest"
          ]
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        },
        "project": {
          "type": "string",
          "minLength": 1
        },
        "live_within_minutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1440
        },
        "active_within_minutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10080
        },
        "cognize_prompt_id": {
          "type": "string",
          "enum": [
            "intent-vector-ru",
            "session-summary"
          ]
        },
        "cognize_provider_chain": {
          "type": "string",
          "minLength": 1
        },
        "cognize_preflight_timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "cognize_runtime_timeout_seconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
