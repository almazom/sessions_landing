{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "intent-extract-result.schema.json",
  "title": "IntentExtractResult",
  "version": "1.5.0",
  "type": "object",
  "required": [
    "meta",
    "source"
  ],
  "anyOf": [
    {
      "required": [
        "intent"
      ]
    },
    {
      "required": [
        "change"
      ]
    }
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "tool",
        "tool_version",
        "generated_at",
        "prompt_id",
        "selected_provider",
        "processing_provider",
        "summary_source"
      ],
      "properties": {
        "tool": {
          "type": "string"
        },
        "tool_version": {
          "type": "string"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "prompt_id": {
          "type": "string"
        },
        "selected_provider": {
          "type": "string"
        },
        "processing_provider": {
          "type": "string"
        },
        "summary_source": {
          "type": "string",
          "enum": [
            "ai",
            "local_fallback",
            "deterministic"
          ]
        },
        "provider_attempts": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "properties": {
        "harness_provider": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "jsonl"
          ]
        },
        "user_message_count": {
          "type": "integer",
          "minimum": 0
        },
        "first_user_message": {
          "type": "string"
        },
        "last_user_message": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "json",
            "jsonl",
            "log"
          ]
        },
        "baseline_at": {
          "type": "string",
          "format": "date-time"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "intent": {
      "type": "object",
      "required": [
        "title",
        "summary",
        "steps"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 3,
          "maxItems": 7,
          "items": {
            "type": "string"
          }
        },
        "key_topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "change": {
      "type": "object",
      "required": [
        "summary",
        "steps",
        "stats",
        "confidence"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "maxItems": 7,
          "items": {
            "type": "string"
          }
        },
        "stats": {
          "type": "object"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
